{
  "mcpServers": {
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp/authv2"
    },
    "aws-knowledge-mcp-server": {
      "args": ["fastmcp", "run", "https://knowledge-mcp.global.api.aws"],
      "autoApprove": [
        "aws___get_regional_availability",
        "aws___list_regions",
        "aws___read_documentation",
        "aws___recommend",
        "aws___search_documentation"
      ],
      "command": "uvx"
    },
    "awslabs.aws-api-mcp-server": {
      "args": ["awslabs.aws-api-mcp-server@latest"],
      "command": "uvx"
    },
    "awslabs.cloudwatch-mcp-server": {
      "args": ["awslabs.cloudwatch-mcp-server@latest"],
      "autoApprove": [],
      "command": "uvx",
      "disabled": false,
      "env": {
        "AWS_DEFAULT_REGION": "us-east-1",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "transportType": "stdio"
    },
    "awslabs.eks-mcp-server": {
      "args": [
        "awslabs.eks-mcp-server@latest",
        "--allow-write",
        "--allow-sensitive-data-access"
      ],
      "autoApprove": [],
      "command": "uvx",
      "disabled": false,
      "env": {
        "AWS_DEFAULT_REGION": "us-east-1",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "coralogix-server": {
      "type": "http",
      "url": "https://api.us2.coralogix.com/mgmt/api/v1/mcp",
      "headers": {
        "Authorization": "Bearer ${CORALOGIX_API_KEY}",
        "mcp-version": "v2"
      }
    },
    "excalidraw": {
      "url": "https://mcp.excalidraw.com"
    },
    "fetch": {
      "args": ["mcp-server-fetch"],
      "command": "uvx"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"],
      "autoApprove": ["read_file", "list_directory", "get_file_stats"]
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    },
    "kubernetes": {
      "args": ["mcp-server-kubernetes"],
      "autoApprove": [
        "explain_resource",
        "kubectl_describe",
        "kubectl_get",
        "kubectl_logs",
        "list_api_resources",
        "ping"
      ],
      "command": "npx",
      "env": {
        "ALLOW_ONLY_NON_DESTRUCTIVE_TOOLS": "true"
      }
    },
    "memory": {
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "autoApprove": [
        "create_entities",
        "create_relations",
        "add_observations",
        "delete_entities",
        "delete_observations",
        "delete_relations",
        "read_graph",
        "search_nodes",
        "open_nodes"
      ],
      "command": "npx"
    },
    "mongodb": {
      "command": "npx",
      "args": ["-y", "mongodb-mcp-server@latest", "--readOnly"]
    },
    "puppeteer": {
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "command": "npx"
    },
    "selenium": {
      "args": ["-y", "@angiejones/mcp-selenium"],
      "autoApprove": [
        "take_screenshot",
        "start_browser",
        "send_keys",
        "right_click",
        "press_key",
        "navigate",
        "hover",
        "get_element_text",
        "find_element",
        "drag_and_drop",
        "double_click",
        "close_session",
        "click_element",
        "upload_file"
      ],
      "command": "npx",
      "disabled_tools": []
    },
    "sequentialthinking": {
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "autoApprove": ["sequentialthinking"],
      "command": "npx"
    }
  },
  "nativeMCPServers": {
    "neovim": {
      "autoApprove": [
        "find_files",
        "list_directory",
        "read_file",
        "read_multiple_files"
      ]
    }
  }
}
